{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "kd": {
    "color": {
      "brand": {
        "blue": { "$type": "color", "$value": "#0339f8", "$description": "KD Electric Blue. The one brand colour. Never tinted, never gradiated in UI." },
        "blue-deep": { "$type": "color", "$value": "#01145a", "$description": "Gradient anchor for placeholder art only." },
        "blue-night": { "$type": "color", "$value": "#020e3e", "$description": "Footer gradient tail." },
        "ink": { "$type": "color", "$value": "#0a0b0e", "$description": "Scrim Ink. Media scrims and footer. Fixed in both themes." },
        "paper-white": { "$type": "color", "$value": "#f4f4f6", "$description": "Text over Scrim Ink." }
      },
      "functional": {
        "error": { "$type": "color", "$value": "#c62f2f" }
      },
      "expressive": {
        "coral": { "$type": "color", "$value": "#ff7a59", "$description": "Playground/illustration only. Never UI chrome." },
        "teal": { "$type": "color", "$value": "#21d4b4", "$description": "Playground/illustration only. Never UI chrome." }
      },
      "light": {
        "bg": { "$type": "color", "$value": "#f6f5f1", "$description": "Warm Paper" },
        "text": { "$type": "color", "$value": "#0e0f12" },
        "muted": { "$type": "color", "$value": "#585e69" },
        "line": { "$type": "color", "$value": "rgba(14,15,18,0.14)" },
        "surface": { "$type": "color", "$value": "#ffffff" },
        "surface-2": { "$type": "color", "$value": "#eceae4" }
      },
      "dark": {
        "bg": { "$type": "color", "$value": "#08090b" },
        "text": { "$type": "color", "$value": "#eceef2" },
        "muted": { "$type": "color", "$value": "#8f939d" },
        "line": { "$type": "color", "$value": "rgba(236,238,242,0.13)" },
        "surface": { "$type": "color", "$value": "#101216" },
        "surface-2": { "$type": "color", "$value": "#16181d" }
      }
    },
    "typography": {
      "family": { "$type": "fontFamily", "$value": ["Instrument Sans", "Helvetica Neue", "Arial", "sans-serif"] },
      "scale": {
        "hero": { "$value": "clamp(2.8rem, 8vw, 6.8rem)" },
        "display": { "$value": "clamp(2.6rem, 6.5vw, 5.5rem)" },
        "title": { "$value": "clamp(2.2rem, 5vw, 4rem)" },
        "heading": { "$value": "clamp(2rem, 4.4vw, 3.6rem)" },
        "subhead": { "$value": "clamp(1.7rem, 3.2vw, 2.5rem)" },
        "lede": { "$value": "clamp(1.35rem, 2.6vw, 1.9rem)" },
        "large": { "$value": "clamp(1.05rem, 1.6vw, 1.35rem)" },
        "body": { "$value": "1.0625rem" },
        "small": { "$value": "0.9rem" },
        "label": { "$value": "0.72rem" },
        "tag": { "$value": "0.62rem" }
      },
      "weight": {
        "display": { "$value": 500 },
        "body": { "$value": 400 },
        "semibold": { "$value": 600 },
        "bold": { "$value": 700 }
      },
      "tracking": {
        "display": { "$value": "-0.02em" },
        "label": { "$value": "0.14em" },
        "tag": { "$value": "0.12em" }
      },
      "leading": {
        "hero": { "$value": 1 },
        "display": { "$value": 1.05 },
        "body": { "$value": 1.65 }
      }
    },
    "space": {
      "pad": { "$value": "clamp(1.25rem, 4vw, 4rem)", "$description": "Page gutter" },
      "section": { "$value": "clamp(4rem, 9vw, 8rem)", "$description": "Vertical section rhythm" },
      "section-sm": { "$value": "clamp(2.5rem, 5vw, 4rem)" },
      "s1": { "$value": "0.25rem" }, "s2": { "$value": "0.5rem" }, "s3": { "$value": "0.8rem" },
      "s4": { "$value": "1.2rem" }, "s5": { "$value": "1.6rem" }, "s6": { "$value": "2.2rem" },
      "s7": { "$value": "3rem" }, "s8": { "$value": "4rem" }
    },
    "shape": {
      "radius": { "$value": "18px" },
      "radius-sm": { "$value": "14px" },
      "radius-xs": { "$value": "10px" },
      "pill": { "$value": "100px" }
    },
    "elevation": {
      "nav": { "$value": "0 8px 32px rgba(10,11,14,0.12)" },
      "hover": { "$value": "0 16px 48px rgba(10,11,14,0.10)" },
      "deep": { "$value": "0 24px 80px rgba(10,11,14,0.18)" }
    },
    "motion": {
      "ease": { "$type": "cubicBezier", "$value": [0.22, 0.7, 0.2, 1], "$description": "The house curve. Every eased transform uses it." },
      "duration": {
        "fast": { "$value": "250ms" },
        "move": { "$value": "350ms" },
        "theme": { "$value": "400ms" },
        "media": { "$value": "800ms" },
        "reveal": { "$value": "900ms" }
      }
    },
    "aspect": {
      "media-card": { "$value": "3 / 2" },
      "media-grid": { "$value": "4 / 3" },
      "media-wide": { "$value": "16 / 9" },
      "portrait": { "$value": "4 / 5" }
    }
  }
}
